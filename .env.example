# Local runtime settings (notification system removed)
SPORTWINNER_API_URL="https://skvb.sportwinner.de/php/skvb/service.php"
SPORTWINNER_REFERER="https://skvb.sportwinner.de/"
SPORTWINNER_TIMEOUT_MS="4500"

# Supabase/PostgreSQL Database
# Create a project at https://supabase.com or https://neon.tech
# Then copy the connection string here

# For Supabase - get this from Settings > Database > Connection string
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT].supabase.co:5432/postgres"

# Alternative: Use a separate database for mirror data (optional)
# MIRROR_DATABASE_URL="postgresql://..."

# SSL mode (default: require SSL)
# For local development with some cloud providers, set to 'disable'
# PGSSLMODE="disable"

# Vercel runtime hints (automatically set by Vercel)
# VERCEL="1"
# NODE_ENV="production"
